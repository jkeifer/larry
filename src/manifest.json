{
  "manifest_version": 3,
  "name": "larry",
  "version": "0.0.0",
  "description": "Pretty-prints, highlights, collapses, and queries (jq) JSON pages. No permissions, no network.",
  "icons": { "16": "icon-16.png", "32": "icon-32.png", "48": "icon-48.png", "128": "icon-128.png" },
  "action": {
    "default_title": "larry — show JSON viewer",
    "default_icon": { "16": "icon-16.png", "32": "icon-32.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["jqjs.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
